NODE_ENV=production
PORT=3000
APP_NAME=Adarsha Pathasala Data Management System
APP_ORIGIN=https://your-frontend-domain.example
REQUIRE_AUTH=true
AUTO_CREATE_ADMIN=true
BOOTSTRAP_ADMIN_EMAIL=admin@adarshapathasala.edu
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase direct database connection string.
# Use the pooled or direct Postgres URL from Supabase Project Settings.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_DB_SSL=true
AUTO_RUN_MIGRATIONS=true

# Firebase Admin SDK service account values
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Public Firebase web config exposed through /api/config.
# These can also be provided as VITE_* variables during frontend builds.
PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
PUBLIC_FIREBASE_APP_ID=your-firebase-web-app-id
PUBLIC_FIREBASE_VAPID_KEY=your-firebase-web-push-vapid-key
